{
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devPath": "http://localhost:3000",
        "distDir": "../out"
    },
    "package": {
        "productName": "asakurawikinotices",
        "version": "1.0.1"
    },
    "tauri": {
        "allowlist": {
            "all": true
        },
        "bundle": {
            "active": true,
            "category": "Utility",
            "identifier": "com.14ninstudio.asakurawikinotices",
            "targets": "all",
            "icon": [
                "icons/32x32.png",
                "icons/128x128.png",
                "icons/128x128@2x.png",
                "icons/icon.icns",
                "icons/icon.ico"
            ] 
        },
        "macOS": {
            "urlAssociations": [
                {
                    "role": "Viewer",
                    "schemes": ["asakurawiki"]
                }
            ]
        },
        "windows": {
            "fullscreen": false,
            "height": 600,
            "resizable": true,
            "title": "AsakuraWiki",
            "width": 800,
            "wix": {
                "language": "ja-JP"
            }
        }
    }
}